{
    "compilerOptions": {
        // ========================================================
        // 1. 디렉토리 및 입출력 설정 (파일 경로 관련)
        // ========================================================
        // 타입스크립트(.ts) 파일들이 모여있는 최상위 시작 폴더입니다.
        "rootDir": "./src",
        // 컴파일(번역)된 자바스크립트(.js) 파일들이 저장될 최종 결과물 폴더입니다.
        "outDir": "./dist",

        // ========================================================
        // 2. 모듈 및 컴파일 환경 설정 (어떤 형태의 JS로 번역할 것인가?)
        // ========================================================
        // 번역될 최종 JS 파일의 문법 버전 (es2016은 대부분의 Node.js 환경에서 안전하게 돌아갑니다)
        "target": "es2016",
        // 생성될 자바스크립트 파일의 모듈 시스템 (Node.js의 전통적인 방식인 CommonJS 사용)
        "module": "CommonJS",
        // 모듈을 찾아내는 방식 (Node.js 환경에서는 무조건 "node"로 설정해야 패키지를 잘 찾습니다)
        "moduleResolution": "node",
        // 컴파일 시 포함할 내장 라이브러리 (esnext는 최신 JS 문법의 내장 기능들을 모두 쓸 수 있게 해줍니다)
        "lib": ["esnext"],
        // 전역으로 포함할 타입 선언 파일 목록 (Node.js 환경의 console, process 등의 타입을 인식하게 해줌)
        "types": ["node"],

        // ========================================================
        // 3. 모듈 호환성 및 가져오기(Import) 규칙
        // ========================================================
        // CommonJS 방식의 모듈을 최신 ESM 방식(import/export)으로 부드럽게 가져올 수 있게 해줍니다.
        // (예: import express from "express" 를 에러 없이 쓰려면 필수!)
        "esModuleInterop": true,
        // (주의) 코드는 최신 import를 쓰는데, 출력은 CommonJS로 할 때 발생하는 문법 충돌 에러를 꺼줍니다.
        // 강사님이 겪으셨던 에러를 해결해 준 핵심 옵션입니다!
        "verbatimModuleSyntax": false,
        // 각 파일을 독립적인 모듈로 취급하여 컴파일합니다. (빠른 빌드 도구나 Babel 등과 호환성을 위해 켬)
        "isolatedModules": true,
        // 파일에 import/export 문이 없어도 강제로 모듈(독립된 파일)로 인식하게 만듭니다. (전역 변수 오염 방지)
        "moduleDetection": "force",
        // import 구문 끝에 ".ts" 확장자를 직접 적는 것을 허용합니다. (특정 번들러나 실행 환경에서 유용함)
        "allowImportingTsExtensions": true,
        // 부작용(Side Effect)만 일으키는 import(예: import "core-js")에 대해 타입 검사를 건너뛰지 않고 엄격히 검사합니다.
        "noUncheckedSideEffectImports": true,

        // ========================================================
        // 4. 엄격한 타입 체크 (에러 방지용)
        // ========================================================
        // 모든 깐깐한 타입 체크 옵션(noImplicitAny, strictNullChecks 등)을 한 번에 다 켭니다. (필수)
        "strict": true,
        // 배열이나 객체에서 값을 꺼낼 때, 값이 없을 수도 있다(undefined)는 것을 타입스크립트가 경고하게 합니다.
        // (예: const a = arr[10]; -> a가 undefined일 수 있음을 경고함. 런타임 에러 방지에 최고!)
        "noUncheckedIndexedAccess": true,
        // 선택적 프로퍼티(name?: string)에 명시적으로 undefined를 넣는 것을 금지합니다.
        // (값이 없으면 아예 프로퍼티 자체를 생략해야 함. 코드의 의도를 명확히 하는 옵션)
        "exactOptionalPropertyTypes": true,
        // 파일 이름의 대소문자를 엄격하게 구별합니다. (윈도우와 맥/리눅스 간의 협업 시 대소문자 오류 방지)
        "forceConsistentCasingInFileNames": true,
        // node_modules 폴더 안에 있는 남이 만든 라이브러리들의 타입 검사는 건너뜁니다.
        // (우리가 짠 코드만 검사하므로 컴파일 속도가 엄청나게 빨라집니다. 필수!)
        "skipLibCheck": true,

        // ========================================================
        // 5. 디버깅 및 기타 설정
        // ========================================================
        // 에러가 났을 때, 번역된 .js 파일의 몇 번째 줄인지가 아니라, 원본 .ts 파일의 몇 번째 줄인지 추적할 수 있는 지도를 만듭니다.
        "sourceMap": true
    }
}
